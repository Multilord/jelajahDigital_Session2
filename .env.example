# Gemini API Keys (backend only, never exposed to frontend)
GEMINI_API_KEYS=key1,key2
GEMINI_MODEL=gemini-2.5-flash

# Firebase Configuration (Vite prefixed for frontend access)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Admin passcode for workshop control
# WARNING: This is embedded in the frontend build and visible to anyone who inspects the JS.
# Acceptable for workshop-level gating only. NOT production-grade security.
VITE_ADMIN_PASSCODE=your_admin_passcode_here
